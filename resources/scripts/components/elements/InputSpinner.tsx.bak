import React from 'react';
import Spinner from '@/components/elements/Spinner';
import Fade from '@/components/elements/Fade';
import tw from 'twin.macro';
import styled, { css } from 'styled-components/macro';

/**
 * InputBorderWrapper — exported from here for convenience.
 * @see `Input.tsx` for the canonical definition.
 */
export { InputBorderWrapper } from '@/components/elements/Input';

// When the spinner is visible, hide the Select dropdown arrow by targeting
// the underlying <select> HTML element (works regardless of styled-component wrapping).
const Container = styled.div<{ visible?: boolean }>`
    ${tw`relative`};

    ${(props) =>
        props.visible &&
        css`
            select {
                background-image: none !important;
            }
        `};
`;

const InputSpinner = ({ visible, children }: { visible: boolean; children: React.ReactNode }) => (
    <Container visible={visible}>
        <Fade appear unmountOnExit in={visible} timeout={150}>
            <div css={tw`absolute right-0 h-full flex items-center justify-end pr-3`} style={{ zIndex: 2, pointerEvents: 'none' }}>
                <Spinner size={'small'} />
            </div>
        </Fade>
        {children}
    </Container>
);

export default InputSpinner;
